# ============================================================================
# Next.js (프론트엔드) 환경변수 - 복사해서 .env.local 로 만들어 사용
# ============================================================================
# SUPABASE_URL 은 브라우저에 노출되어도 안전 (공개 URL).
# ANON_KEY 도 공개 키 (RLS 정책이 읽기/쓰기 권한을 통제).
# SERVICE_ROLE_KEY 는 RLS 를 우회하므로 절대 NEXT_PUBLIC_ 접두어 없이 사용.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
